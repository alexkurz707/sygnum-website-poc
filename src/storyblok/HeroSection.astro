---
import { storyblokEditable } from '@storyblok/astro';
const { blok } = Astro.props;
const bgImage = blok.background_image?.filename;
---

<section
  id="hero"
  {...storyblokEditable(blok)}
  style="background-color: #ffffff; overflow: hidden; border-bottom: 1px solid #eeedf3;"
>
  <div style="
    max-width: 1320px;
    margin: 0 auto;
    padding: 5.5rem 2rem;
    display: grid;
    grid-template-columns: 45% 55%;
    align-items: center;
    gap: 4rem;
    min-height: 480px;
  ">

    <!-- LEFT — text (45%) -->
    <div>
      <h1 style="
        font-size: clamp(2rem, 3.2vw, 3rem);
        font-weight: 300;
        color: #1a1a2e;
        line-height: 1.15;
        letter-spacing: -0.02em;
        margin: 0 0 1.375rem 0;
        font-family: 'Calibri Light', Calibri, Arial, sans-serif;
      ">
        {blok.heading}
      </h1>

      {blok.subheading && (
        <p style="
          font-size: 0.9375rem;
          color: #555567;
          line-height: 1.72;
          margin: 0 0 2.5rem 0;
          font-weight: 300;
          font-family: 'Calibri Light', Calibri, Arial, sans-serif;
        ">
          {blok.subheading}
        </p>
      )}

      <div style="display:flex; align-items:center; gap:0.875rem; flex-wrap:wrap;">
        {blok.button_text && blok.button_link && (
          <a href={blok.button_link} class="btn-coral">{blok.button_text}</a>
        )}
        <a href="#contact" class="btn-outline-coral" style="display:inline-flex;align-items:center;gap:0.35rem;">
          Contact us
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
            <path d="M2.5 6.5h8M7.5 3.5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- RIGHT — image (55%) -->
    <div style="height:100%; display:flex; align-items:center; justify-content:center;">
      {bgImage
        ? (
          <img
            src={bgImage}
            alt=""
            style="width:100%; max-height:420px; object-fit:contain; display:block;"
          />
        )
        : (
          <!-- Clean placeholder — replace by uploading a background_image in Storyblok -->
          <div style="
            width: 100%;
            max-width: 500px;
            aspect-ratio: 4/3;
            background-color: #f0eef6;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            color: #aaa8b8;
          ">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="4" y="8" width="32" height="24" rx="2" stroke="#CFCDDA" stroke-width="1.5"/>
              <circle cx="14" cy="17" r="3" stroke="#CFCDDA" stroke-width="1.5"/>
              <path d="M4 28l8-7 6 5 5-4 9 8" stroke="#CFCDDA" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span style="font-size:0.75rem; font-family:'Calibri Light',Calibri,Arial,sans-serif; letter-spacing:0.04em;">
              Upload image in Storyblok → background_image
            </span>
          </div>
        )
      }
    </div>

  </div>
</section>
