---
import { storyblokEditable } from '@storyblok/astro';
const { blok } = Astro.props;
const iconUrl = blok.icon?.filename;
---

<div
  {...storyblokEditable(blok)}
  style="
    background-color: #F5F4F8;
    border: 1px solid #e4e2ec;
    padding: 1.75rem 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease;
    cursor: default;
  "
  onmouseenter="this.style.borderColor='#F04E68'"
  onmouseleave="this.style.borderColor='#e4e2ec'"
>

  <!-- Top row: coral + icon -->
  <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:1.25rem;">

    <!-- Coral plus icon — top left -->
    <div style="
      width: 30px; height: 30px;
      background-color: #F04E68;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    ">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M7 2v10M2 7h10" stroke="white" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </div>

    <!-- Icon image top-right: real image from Storyblok, or grey placeholder square -->
    {iconUrl
      ? (
        <img
          src={iconUrl}
          alt=""
          style="width:44px; height:44px; object-fit:contain; display:block;"
        />
      )
      : (
        <div style="
          width:44px; height:44px;
          background-color: #e4e2ec;
          display:flex; align-items:center; justify-content:center;
        ">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="2" y="4" width="14" height="10" rx="1" stroke="#CFCDDA" stroke-width="1.2"/>
            <circle cx="6.5" cy="8" r="1.5" stroke="#CFCDDA" stroke-width="1.2"/>
            <path d="M2 13l4-3 3 2.5 2.5-2 4.5 3.5" stroke="#CFCDDA" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      )
    }
  </div>

  <!-- Title -->
  <h3 style="
    font-size: 1rem; font-weight: 400; color: #1a1a2e;
    line-height: 1.3; margin: 0 0 0.75rem 0;
    font-family: 'Calibri Light', Calibri, Arial, sans-serif;
  ">
    {blok.title}
  </h3>

  <!-- Description -->
  <p style="
    font-size: 0.84rem; color: #6b6a7a; line-height: 1.68;
    font-weight: 300; margin: 0; flex: 1;
    font-family: 'Calibri Light', Calibri, Arial, sans-serif;
  ">
    {blok.description}
  </p>

  <!-- Learn More -->
  <a
    href="#"
    style="
      display:inline-flex; align-items:center; gap:0.35rem;
      font-size:0.8rem; color:#F04E68; text-decoration:none;
      letter-spacing:0.03em; margin-top:1.25rem;
      transition: gap 0.15s;
    "
    onmouseenter="this.style.gap='0.55rem'"
    onmouseleave="this.style.gap='0.35rem'"
  >
    Learn More
    <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
      <path d="M2.5 6.5h8M7.5 3.5l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>

</div>
